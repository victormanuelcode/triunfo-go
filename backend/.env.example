# Configuración de correo (recuperación de contraseña)
# MAIL_DRIVER=log  → NO envía correo real; el código aparece en pantalla (dev) y en backend/logs/mail.log
# MAIL_DRIVER=smtp → Envío real (Gmail, Outlook, etc.)
MAIL_DRIVER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@triunfogo.com
MAIL_FROM_NAME="TRIUNFO GO"
